<html>
  <head>
    <title>Mini Messageboard</title>
    <link rel="stylesheet" href="../styles.css">
  </head>
  <body>
    <ul>
      <% let count = 0 %>
      <% messages.forEach((message) => { %>
        <li>Message: <%= message.text %></li>
        <li>User: <%= message.user %></li>
        <li>Added at: <%= message.added %></li>
        <form method="GET" action="/details/<%= count %>">
          <button type="submit" class="openDetails" id=<%= count %>>Open details</button>
        </form>
        <hr>
        <% count++ %>
      <% }); %>
    </ul>
    <form method="GET" action="/new">
      <button type="submit" class="newMessage">New Message</button>
    </form>
  </body>
</html>