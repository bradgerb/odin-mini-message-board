<html>
  <head>
    <title>About</title>
    <link rel="stylesheet" href="../styles.css">
  </head>
  <body>
    <ul>
      <% messages.forEach((message) => { %>
        <li>Message: <%= message.text %></li>
        <li>User: <%= message.user %></li>
        <li>Added at: <%= message.added %></li>
        <hr>
      <% }); %>
    </ul>
  </body>
</html>