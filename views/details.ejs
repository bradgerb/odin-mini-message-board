<html>
  <head>
    <title>Message Details</title>
    <link rel="stylesheet" href="../styles.css">
  </head>
  <body>
    <ul>
        <li>Message: <%= messages[detailID].text %></li>
        <li>User: <%= messages[detailID].user %></li>
        <li>Added at: <%= messages[detailID].added %></li>
    </ul>
    <form method="GET" action="/">
        <button type="submit" class="backButton">Back</button>
    </form>
  </body>
</html>